# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# Models (adaptive: cheapest model that fits each job; override only if needed)
# Live WhatsApp path = router (classify + detect language) -> intervention specialist.
MALARIA_ROUTER_MODEL=claude-haiku-4-5       # fast classifier: language/intent/intervention
MALARIA_SPECIALIST_MODEL=claude-sonnet-4-6  # the intervention expert that writes the reply

# Legacy three-agent loop (kept only for the offline eval / demo script)
MALARIA_ACK_MODEL=claude-haiku-4-5
MALARIA_NAVIGATOR_MODEL=claude-sonnet-4-6
MALARIA_ADVERSARIAL_MODEL=claude-sonnet-4-6
MALARIA_VERIFIER_MODEL=claude-haiku-4-5
MALARIA_ESCALATION_MODEL=claude-opus-4-8
MALARIA_EFFORT=low
MALARIA_MAX_ROUNDS=3
MALARIA_RUBRIC_THRESHOLD=7

# --- Twilio WhatsApp (sandbox is free + instant) ---
# https://www.twilio.com/console/sms/whatsapp/sandbox
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# The Twilio sandbox WhatsApp number, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Set to "1" to verify inbound webhook signatures (recommended in prod)
TWILIO_VALIDATE_SIGNATURE=0

# Where per-phone session memory JSON files live
MALARIA_SESSION_DIR=./sessions

# --- Maps on WhatsApp ---
# Public https base URL Twilio uses to fetch generated map images.
# Set this to your tunnel/host (no trailing slash, no /maps), e.g. your
# cloudflared/ngrok URL. If empty, replies are sent without a map image.
MALARIA_PUBLIC_BASE_URL=
# Attach a region risk map to replies (1=on, 0=off)
MALARIA_SEND_MAPS=1
# Where rendered map PNGs are written
MALARIA_MAPS_DIR=./maps_out
